@"
# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
env/
venv/
sql_venv/
.env
.env.local

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
"@ | Out-File -Encoding UTF8 .gitignore

# Create .gitattributes
@"
* text=auto
*.py text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
"@ | Out-File -Encoding UTF8 .gitattributes